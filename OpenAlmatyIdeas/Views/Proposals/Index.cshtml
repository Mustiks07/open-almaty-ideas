@model IEnumerable<ProposalDTO>

@{
    ViewData["Title"] = L["Proposals.PageTitle"].Value;
    var districts = ViewBag.Districts as IEnumerable<OpenAlmatyIdeas.Domain.Entities.District> ?? [];
    var categories = ViewBag.Categories as IEnumerable<OpenAlmatyIdeas.Domain.Entities.Category> ?? [];
    int? currentDistrictId = ViewBag.CurrentDistrictId;
    int? currentCategoryId = ViewBag.CurrentCategoryId;
    string? search = ViewBag.Search;
    string? sort = ViewBag.Sort;
}

<div class="container-xl px-4">

    <div class="page-header d-flex align-items-center justify-content-between">
        <div>
            <h1>@L["Proposals.PageTitle"]</h1>
            <p class="lead">@L["Proposals.Subtitle"]</p>
        </div>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-action="New" class="btn-brand">@L["Proposals.NewBtn"]</a>
        }
    </div>

    <!-- Filters -->
    <form method="get" asp-action="Index" class="filter-form">
        <div class="row g-2">
            <div class="col-md-4">
                <input type="text" name="search" value="@search" class="form-control"
                       placeholder="@L["Proposals.SearchPlaceholder"]" />
            </div>
            <div class="col-md-3">
                <select name="districtId" class="form-select">
                    <option value="">@L["Proposals.AllDistricts"]</option>
                    @foreach (var d in districts)
                    {
                        <option value="@d.Id" selected="@(currentDistrictId == d.Id)">@d.Title</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <select name="categoryId" class="form-select">
                    <option value="">@L["Proposals.AllCategories"]</option>
                    @foreach (var c in categories)
                    {
                        <option value="@c.Id" selected="@(currentCategoryId == c.Id)">@c.Title</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select name="sort" class="form-select">
                    <option value="" selected="@(sort == null)">@L["Proposals.SortNew"]</option>
                    <option value="popular" selected="@(sort == "popular")">@L["Proposals.SortPopular"]</option>
                </select>
            </div>
        </div>
        <div class="mt-2 d-flex gap-2 align-items-center">
            <button type="submit" class="btn-brand btn-sm">@L["Proposals.Apply"]</button>
            @if (!string.IsNullOrEmpty(search) || currentDistrictId.HasValue || currentCategoryId.HasValue || sort != null)
            {
                <a asp-action="Index" class="btn-glass btn-sm">@L["Proposals.Reset"]</a>
            }
        </div>
    </form>

    <!-- Results -->
    @if (!Model.Any())
    {
        <div class="alert alert-info">
            @L["Proposals.NotFound"]
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-action="New" style="color:#93C5FD">@L["Proposals.BeFirst"]</a>
            }
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var proposal in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 hover-lift">
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-3">
                                <span class="badge bg-secondary">@proposal.CategoryName</span>
                                <span class="badge
                                    @(proposal.Status == ProposalStatusEnum.Implemented ? "bg-success" :
                                      proposal.Status == ProposalStatusEnum.Accepted ? "bg-primary" :
                                      proposal.Status == ProposalStatusEnum.Rejected ? "bg-danger" :
                                      "bg-warning")">
                                    @L[$"Status.{proposal.Status}"]
                                </span>
                            </div>
                            <h5 class="card-title mb-2">
                                <a asp-action="Show" asp-route-id="@proposal.Id"
                                   class="stretched-link text-decoration-none">
                                    @proposal.Title
                                </a>
                            </h5>
                            <p class="card-text small"
                               style="display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden">
                                @proposal.DescriptionShort
                            </p>
                        </div>
                        <div class="card-footer d-flex justify-content-between small">
                            <span>📍 @proposal.DistrictName</span>
                            <span>
                                <span class="text-success">👍 @proposal.LikesCount</span>
                                <span class="ms-2" style="color:#F87171">👎 @proposal.DislikesCount</span>
                            </span>
                        </div>
                    </div>
                </div>
            }
        </div>
        <p class="mt-3" style="color:rgba(255,255,255,0.35);font-size:0.8rem">
            @L["Proposals.Shown"] @Model.Count() @L["Proposals.ShownSuffix"]
        </p>
    }

</div>
