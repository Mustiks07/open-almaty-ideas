@model IEnumerable<ProposalDTO>

@{
    ViewData["Title"] = "Предложения";
    var districts = ViewBag.Districts as IEnumerable<OpenAlmatyIdeas.Domain.Entities.District> ?? [];
    var categories = ViewBag.Categories as IEnumerable<OpenAlmatyIdeas.Domain.Entities.Category> ?? [];
    int? currentDistrictId = ViewBag.CurrentDistrictId;
    int? currentCategoryId = ViewBag.CurrentCategoryId;
    string? search = ViewBag.Search;
    string? sort = ViewBag.Sort;
}

<div class="row mb-4 align-items-center">
    <div class="col">
        <h1>Предложения</h1>
    </div>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="col-auto">
            <a asp-action="New" class="btn btn-success">+ Новое предложение</a>
        </div>
    }
</div>

<!-- Поиск и фильтры -->
<form method="get" asp-action="Index" class="mb-4">
    <div class="row g-2">
        <div class="col-md-4">
            <input type="text" name="search" value="@search" class="form-control"
                   placeholder="🔍 Поиск по названию..." />
        </div>
        <div class="col-md-3">
            <select name="districtId" class="form-select">
                <option value="">Все районы</option>
                @foreach (var d in districts)
                {
                    <option value="@d.Id" selected="@(currentDistrictId == d.Id)">@d.Title</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <select name="categoryId" class="form-select">
                <option value="">Все категории</option>
                @foreach (var c in categories)
                {
                    <option value="@c.Id" selected="@(currentCategoryId == c.Id)">@c.Title</option>
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="sort" class="form-select">
                <option value="" selected="@(sort == null)">Новые</option>
                <option value="popular" selected="@(sort == "popular")">Популярные</option>
            </select>
        </div>
    </div>
    <div class="mt-2 d-flex gap-2">
        <button type="submit" class="btn btn-primary btn-sm">Применить</button>
        @if (!string.IsNullOrEmpty(search) || currentDistrictId.HasValue || currentCategoryId.HasValue || sort != null)
        {
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm">✕ Сбросить</a>
        }
    </div>
</form>

<!-- Список предложений -->
@if (!Model.Any())
{
    <div class="alert alert-info">
        Предложений не найдено.
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-action="New">Будьте первым!</a>
        }
    </div>
}
else
{
    <div class="row">
        @foreach (var proposal in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="badge bg-secondary">@proposal.CategoryName</span>
                            <span class="badge
                                @(proposal.Status == ProposalStatusEnum.Implemented ? "bg-success" :
                                  proposal.Status == ProposalStatusEnum.Accepted ? "bg-primary" :
                                  proposal.Status == ProposalStatusEnum.Rejected ? "bg-danger" :
                                  "bg-warning text-dark")">
                                @proposal.StatusLabel
                            </span>
                        </div>
                        <h5 class="card-title">
                            <a asp-action="Show" asp-route-id="@proposal.Id" class="text-decoration-none stretched-link">
                                @proposal.Title
                            </a>
                        </h5>
                        <p class="card-text text-muted small">@proposal.DescriptionShort</p>
                    </div>
                    <div class="card-footer d-flex justify-content-between small text-muted">
                        <span>📍 @proposal.DistrictName</span>
                        <span>
                            <span class="text-success">👍 @proposal.LikesCount</span>
                            <span class="text-danger ms-2">👎 @proposal.DislikesCount</span>
                        </span>
                    </div>
                </div>
            </div>
        }
    </div>
    <p class="text-muted small">Показано: @Model.Count() предложений</p>
}
