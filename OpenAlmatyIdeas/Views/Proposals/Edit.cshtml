@model CreateProposalViewModel

@{
    ViewData["Title"] = L["EditProposal.Title"].Value;
    var proposalId = ViewBag.ProposalId;
}

<div class="container-xl px-4 py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">

            <div class="page-header">
                <h1>@L["EditProposal.Title"]</h1>
                <p class="lead">@L["EditProposal.Subtitle"]</p>
            </div>

            <div class="auth-card">
                <form asp-action="Edit" asp-route-id="@proposalId" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4"></div>

                    <div class="mb-4">
                        <label asp-for="Title" class="form-label">@L["NewProposal.NameLabel"]</label>
                        <input asp-for="Title" class="form-control" />
                        <span asp-validation-for="Title" class="field-validation-error"></span>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6 mb-3 mb-md-0">
                            <label asp-for="DistrictId" class="form-label">@L["NewProposal.DistrictLabel"]</label>
                            <select asp-for="DistrictId" class="form-select"
                                    asp-items="@(new SelectList(Model.Districts, "Id", "Title"))">
                                <option value="">@L["NewProposal.DistrictDefault"]</option>
                            </select>
                            <span asp-validation-for="DistrictId" class="field-validation-error"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="CategoryId" class="form-label">@L["NewProposal.CategoryLabel"]</label>
                            <select asp-for="CategoryId" class="form-select"
                                    asp-items="@(new SelectList(Model.Categories, "Id", "Title"))">
                                <option value="">@L["NewProposal.CategoryDefault"]</option>
                            </select>
                            <span asp-validation-for="CategoryId" class="field-validation-error"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="DescriptionShort" class="form-label">@L["NewProposal.ShortDescLabel"]</label>
                        <textarea asp-for="DescriptionShort" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="DescriptionShort" class="field-validation-error"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Description" class="form-label">@L["NewProposal.FullDescLabel"]</label>
                        <textarea asp-for="Description" class="form-control" rows="8"></textarea>
                        <span asp-validation-for="Description" class="field-validation-error"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Files" class="form-label"></label>
                        <input asp-for="Files" type="file" multiple accept="image/*,video/*" class="form-control" />
                        <div class="form-text text-muted" style="font-size:0.75rem;margin-top:0.3rem">
                            Уже загруженные файлы сохраняются. Новые файлы будут добавлены к существующим.
                        </div>
                        <span asp-validation-for="Files" class="field-validation-error"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn-brand">@L["EditProposal.SaveChanges"]</button>
                        <a asp-controller="Proposals" asp-action="Show" asp-route-id="@proposalId"
                           class="btn-glass">@L["EditProposal.Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
