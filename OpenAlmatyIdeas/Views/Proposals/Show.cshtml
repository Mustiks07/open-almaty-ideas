@model ProposalDTO

@{
    ViewData["Title"] = Model.Title;
    var currentVote = ViewBag.CurrentVote as VoteTypeEnum?;
    var currentUserId = ViewBag.CurrentUserId as string;
    var isAuthor = currentUserId != null && currentUserId == Model.AuthorId;
    var isAdmin = User.IsInRole("Admin");

    string statusClass = Model.Status switch
    {
        ProposalStatusEnum.Implemented => "bg-success",
        ProposalStatusEnum.Accepted    => "bg-primary",
        ProposalStatusEnum.Rejected    => "bg-danger",
        _                              => "bg-warning"
    };
    string responseClass = Model.Status switch
    {
        ProposalStatusEnum.Implemented => "status-implemented",
        ProposalStatusEnum.Accepted    => "status-accepted",
        ProposalStatusEnum.Rejected    => "status-rejected",
        _                              => "status-pending"
    };
}

<div class="container-xl px-4 py-4">
    <div class="row g-4">

        <!-- Main content -->
        <div class="col-lg-8">

            <a asp-action="Index" class="back-link">
                @L["Proposal.Back"]
            </a>

            <div class="d-flex align-items-start gap-3 mb-3 flex-wrap">
                <h1 class="show-title">
                    @Model.Title
                </h1>
                <span class="badge @statusClass fs-6">@L[$"Status.{Model.Status}"]</span>
            </div>

            <div class="d-flex flex-wrap gap-3 mb-4 show-meta">
                <span>📍 @Model.DistrictName</span>
                <span>🏷️ @Model.CategoryName</span>
                <span>👤 @Model.AuthorName</span>
                <span>📅 @Model.DateCreated.ToString("dd.MM.yyyy")</span>
            </div>

            @if (isAuthor || isAdmin)
            {
                <div class="d-flex gap-2 mb-4">
                    @if (isAuthor)
                    {
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-glass btn-sm btn-action-edit">
                            @L["Proposal.Edit"]
                        </a>
                    }
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                        <button type="submit" class="btn-glass btn-sm btn-action-delete"
                                onclick="return confirm('@L["Proposal.DeleteConfirm"]')">
                            @L["Proposal.Delete"]
                        </button>
                    </form>
                </div>
            }

            @if (!string.IsNullOrEmpty(Model.DescriptionShort))
            {
                <p class="lead mb-4 show-description-short">
                    @Model.DescriptionShort
                </p>
            }

            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="mb-4 show-description">
                    @Html.Raw(Model.Description)
                </div>
            }

            @if (Model.Media.Any())
            {
                <div class="row g-2 mb-4">
                    @foreach (var media in Model.Media.Where(m => m.Type == MediaTypeEnum.Image))
                    {
                        <div class="col-md-6">
                            <img src="@media.Url" alt="@media.FileName"
                                 class="img-fluid rounded show-media-img" />
                        </div>
                    }
                    @foreach (var media in Model.Media.Where(m => m.Type == MediaTypeEnum.Video))
                    {
                        <div class="col-12">
                            <video controls class="w-100 rounded show-media-video">
                                <source src="@media.Url" />
                            </video>
                        </div>
                    }
                </div>
            }

            @if (Model.AdminResponses.Any())
            {
                <div class="mb-4">
                    <h5 class="show-admin-title">
                        @L["Proposal.AdminResponses"]
                    </h5>
                    @foreach (var response in Model.AdminResponses)
                    {
                        <div class="admin-response-card @responseClass">
                            <p class="show-response-text">@response.Text</p>
                            <small class="show-response-meta">
                                @response.AdminName — @response.DateCreated.ToString("dd.MM.yyyy HH:mm")
                            </small>
                        </div>
                    }
                </div>
            }

        </div>

        <!-- Sidebar -->
        <div class="col-lg-4">

            <div class="vote-card">
                <h6 class="vote-heading">
                    @L["Proposal.Voting"]
                </h6>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="d-flex justify-content-center gap-3">
                        <form asp-action="Vote" method="post">
                            <input type="hidden" name="proposalId" value="@Model.Id" />
                            <input type="hidden" name="voteType" value="@VoteTypeEnum.Like" />
                            <button type="submit"
                                    class="btn-vote-like @(currentVote == VoteTypeEnum.Like ? "voted" : "")">
                                👍 @Model.LikesCount
                            </button>
                        </form>
                        <form asp-action="Vote" method="post">
                            <input type="hidden" name="proposalId" value="@Model.Id" />
                            <input type="hidden" name="voteType" value="@VoteTypeEnum.Dislike" />
                            <button type="submit"
                                    class="btn-vote-dislike @(currentVote == VoteTypeEnum.Dislike ? "voted" : "")">
                                👎 @Model.DislikesCount
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <p class="vote-login-text">
                        <a asp-controller="Account" asp-action="Login">@L["Proposal.LoginToVote"]</a>@L["Proposal.ToVote"]
                    </p>
                    <div class="d-flex justify-content-center gap-4">
                        <span class="vote-count-like">👍 @Model.LikesCount</span>
                        <span class="vote-count-dislike">👎 @Model.DislikesCount</span>
                    </div>
                }
            </div>

            <div class="info-panel">
                <h6 class="info-heading">
                    @L["Proposal.Info"]
                </h6>
                <div class="d-flex flex-column gap-2" style="font-size:0.85rem">
                    <div class="d-flex justify-content-between">
                        <span class="info-label">@L["Proposal.Status"]</span>
                        <span class="badge @statusClass">@L[$"Status.{Model.Status}"]</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="info-label">@L["Proposal.District"]</span>
                        <span class="info-value">@Model.DistrictName</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="info-label">@L["Proposal.Category"]</span>
                        <span class="info-value">@Model.CategoryName</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="info-label">@L["Proposal.Author"]</span>
                        <span class="info-value">@Model.AuthorName</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="info-label">@L["Proposal.Date"]</span>
                        <span class="info-value">@Model.DateCreated.ToString("dd.MM.yyyy")</span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
