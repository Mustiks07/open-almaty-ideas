@model ProposalDTO

@{
    ViewData["Title"] = Model.Title;
    var currentVote = ViewBag.CurrentVote as VoteTypeEnum?;
    var currentUserId = ViewBag.CurrentUserId as string;
    var isAuthor = currentUserId != null && currentUserId == Model.AuthorId;
    var isAdmin = User.IsInRole("Admin");
}

<div class="row">
    <div class="col-md-8">
        <!-- Заголовок и статус -->
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h1 class="h2">@Model.Title</h1>
            <span class="badge fs-6 ms-2
                @(Model.Status == ProposalStatusEnum.Implemented ? "bg-success" :
                  Model.Status == ProposalStatusEnum.Accepted ? "bg-primary" :
                  Model.Status == ProposalStatusEnum.Rejected ? "bg-danger" :
                  "bg-warning text-dark")">
                @Model.StatusLabel
            </span>
        </div>

        <!-- Мета-информация -->
        <div class="text-muted small mb-4 d-flex flex-wrap gap-3">
            <span>📍 @Model.DistrictName</span>
            <span>🏷️ @Model.CategoryName</span>
            <span>👤 @Model.AuthorName</span>
            <span>📅 @Model.DateCreated.ToString("dd.MM.yyyy")</span>
        </div>

        <!-- Кнопки автора -->
        @if (isAuthor || isAdmin)
        {
            <div class="d-flex gap-2 mb-4">
                @if (isAuthor)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id"
                       class="btn btn-sm btn-outline-primary">✏️ Редактировать</a>
                }
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                      onsubmit="return confirm('Удалить предложение?')">
                    <button type="submit" class="btn btn-sm btn-outline-danger">🗑️ Удалить</button>
                </form>
            </div>
        }

        <!-- Краткое описание -->
        @if (!string.IsNullOrEmpty(Model.DescriptionShort))
        {
            <p class="lead border-start border-4 border-success ps-3">@Model.DescriptionShort</p>
        }

        <!-- Полное описание -->
        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="mb-4">@Html.Raw(Model.Description)</div>
        }

        <!-- Медиа файлы -->
        @if (Model.Media.Any())
        {
            <div class="row mb-4 g-2">
                @foreach (var media in Model.Media.Where(m => m.Type == MediaTypeEnum.Image))
                {
                    <div class="col-md-6">
                        <img src="@media.Url" alt="@media.FileName"
                             class="img-fluid rounded shadow-sm w-100" style="object-fit:cover;max-height:300px;" />
                    </div>
                }
                @foreach (var media in Model.Media.Where(m => m.Type == MediaTypeEnum.Video))
                {
                    <div class="col-12">
                        <video controls class="w-100 rounded">
                            <source src="@media.Url" />
                        </video>
                    </div>
                }
            </div>
        }

        <!-- Ответы администратора -->
        @if (Model.AdminResponses.Any())
        {
            <div class="mb-4">
                <h5 class="mb-3">💬 Ответы администратора</h5>
                @foreach (var response in Model.AdminResponses)
                {
                    <div class="card border-start border-4
                        @(Model.Status == ProposalStatusEnum.Implemented ? "border-success" :
                          Model.Status == ProposalStatusEnum.Accepted ? "border-primary" :
                          Model.Status == ProposalStatusEnum.Rejected ? "border-danger" :
                          "border-warning") mb-3">
                        <div class="card-body">
                            <p class="mb-1">@response.Text</p>
                            <small class="text-muted">
                                @response.AdminName — @response.DateCreated.ToString("dd.MM.yyyy HH:mm")
                            </small>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Боковая панель -->
    <div class="col-md-4">
        <!-- Голосование -->
        <div class="card mb-4">
            <div class="card-body text-center">
                <h5 class="card-title mb-3">Голосование</h5>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="d-flex justify-content-center gap-3">
                        <form asp-action="Vote" method="post">
                            <input type="hidden" name="proposalId" value="@Model.Id" />
                            <input type="hidden" name="voteType" value="@VoteTypeEnum.Like" />
                            <button type="submit"
                                    class="btn @(currentVote == VoteTypeEnum.Like ? "btn-success" : "btn-outline-success") btn-lg">
                                👍 @Model.LikesCount
                            </button>
                        </form>
                        <form asp-action="Vote" method="post">
                            <input type="hidden" name="proposalId" value="@Model.Id" />
                            <input type="hidden" name="voteType" value="@VoteTypeEnum.Dislike" />
                            <button type="submit"
                                    class="btn @(currentVote == VoteTypeEnum.Dislike ? "btn-danger" : "btn-outline-danger") btn-lg">
                                👎 @Model.DislikesCount
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <p class="text-muted small">
                        <a asp-controller="Account" asp-action="Login">Войдите</a>, чтобы проголосовать
                    </p>
                    <div class="d-flex justify-content-center gap-4 mt-2">
                        <span class="fs-5 text-success">👍 @Model.LikesCount</span>
                        <span class="fs-5 text-danger">👎 @Model.DislikesCount</span>
                    </div>
                }
            </div>
        </div>

        <a asp-action="Index" class="btn btn-outline-secondary w-100">← Все предложения</a>
    </div>
</div>
