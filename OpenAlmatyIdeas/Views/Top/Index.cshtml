@model IEnumerable<ProposalDTO>

@{
    ViewData["Title"] = "Топ идей";
}

<h1 class="mb-4">🏆 Топ идей</h1>
<p class="text-muted mb-4">Предложения с наибольшим количеством голосов</p>

@if (!Model.Any())
{
    <div class="alert alert-info">Голосования пока нет. Будьте первым!</div>
}
else
{
    <div class="list-group">
        @{var rank = 1;}
        @foreach (var proposal in Model)
        {
            <a asp-controller="Proposals" asp-action="Show" asp-route-id="@proposal.Id"
               class="list-group-item list-group-item-action d-flex gap-3 py-3">
                <div class="display-6 fw-bold text-success" style="min-width: 40px">
                    @rank
                </div>
                <div class="flex-grow-1">
                    <div class="d-flex justify-content-between">
                        <h5 class="mb-1">@proposal.Title</h5>
                        <span class="badge bg-secondary">@proposal.CategoryName</span>
                    </div>
                    <p class="mb-1 text-muted small">@proposal.DescriptionShort</p>
                    <small class="text-muted">📍 @proposal.DistrictName</small>
                </div>
                <div class="text-end">
                    <div class="text-success fw-bold">👍 @proposal.LikesCount</div>
                    <div class="text-danger small">👎 @proposal.DislikesCount</div>
                </div>
            </a>
            rank++;
        }
    </div>
}
