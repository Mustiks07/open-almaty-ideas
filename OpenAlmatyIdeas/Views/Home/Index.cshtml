@{
    ViewData["Title"] = L["Home.PageTitle"].Value;
    var topProposals = ViewBag.TopProposals as IEnumerable<OpenAlmatyIdeas.Models.ProposalDTO> ?? [];
    var districts = ViewBag.Districts as IEnumerable<OpenAlmatyIdeas.Domain.Entities.District> ?? [];
    int totalProposals = ViewBag.TotalProposals ?? 0;
    int totalDistricts = ViewBag.TotalDistricts ?? 0;
    int totalCategories = ViewBag.TotalCategories ?? 0;
}

<!-- Hero -->
<div class="hero-section">
    <!-- Dark overlay -->
    <div class="hero-overlay"></div>

    <div class="hero-content position-relative">
        <div class="container-xl px-4">
            <div class="row justify-content-center text-center">
                <div class="col-lg-7">
                    <div class="hero-tagline animate-fade-up">@L["Home.TagLine"]</div>
                    <h1 class="hero-title animate-fade-up-d1">
                        Open <span class="text-gradient">Almaty</span><br/>
                        Ideas
                    </h1>
                    <p class="hero-subtitle-main animate-fade-up-d2">@L["Home.HeroMain"]</p>
                    <p class="hero-subtitle animate-fade-up-d2">@L["Home.HeroSubtitle"]</p>
                    <div class="d-flex gap-3 justify-content-center flex-wrap animate-fade-up-d3">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="Proposals" asp-action="New" class="btn-hero-primary">
                                @L["Home.SuggestIdea"]
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Register" class="btn-hero-primary">
                                @L["Home.JoinUs"]
                            </a>
                        }
                        <a asp-controller="Proposals" asp-action="Index" class="btn-hero-secondary">
                            @L["Home.ViewProposals"]
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Scroll indicator -->
        <div class="hero-scroll-indicator animate-fade-up-d4">
            <div class="scroll-mouse">
                <div class="scroll-dot"></div>
            </div>
        </div>
    </div>
</div>

<!-- Main content -->
<div class="container-xl px-4">

    <!-- Stats -->
    <div class="row g-3 my-4">
        <div class="col-4 animate-fade-up-d1">
            <div class="stat-card">
                <div class="stat-number">@totalProposals</div>
                <div class="stat-label">@L["Home.StatProposals"]</div>
            </div>
        </div>
        <div class="col-4 animate-fade-up-d2">
            <div class="stat-card">
                <div class="stat-number">@totalDistricts</div>
                <div class="stat-label">@L["Home.StatDistricts"]</div>
            </div>
        </div>
        <div class="col-4 animate-fade-up-d3">
            <div class="stat-card">
                <div class="stat-number">@totalCategories</div>
                <div class="stat-label">@L["Home.StatCategories"]</div>
            </div>
        </div>
    </div>

    <!-- Top proposals -->
    @if (topProposals.Any())
    {
        <div class="mt-5 mb-4">
            <span class="section-tag">@L["Home.RatingTag"]</span>
            <h2 class="section-title">@L["Home.TopProposals"]</h2>
            <p class="section-subtitle">@L["Home.TopSubtitle"]</p>
        </div>
        <div class="row g-3 mb-5">
            @{ int rank = 1; }
            @foreach (var proposal in topProposals)
            {
                <div class="col-md-4 animate-fade-up-d@(rank <= 4 ? rank : 4)">
                    <div class="card h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="d-flex gap-2 align-items-center">
                                    <div class="card-rank">#@rank</div>
                                    <span class="badge bg-secondary">@proposal.CategoryName</span>
                                </div>
                                <partial name="_StatusBadge" model="proposal.Status" />
                            </div>
                            <h5 class="card-title mb-2">
                                <a asp-controller="Proposals" asp-action="Show"
                                   asp-route-id="@proposal.Id" class="stretched-link text-decoration-none">
                                    @proposal.Title
                                </a>
                            </h5>
                            <p class="card-text" style="-webkit-line-clamp:2;overflow:hidden;display:-webkit-box;-webkit-box-orient:vertical">
                                @proposal.DescriptionShort
                            </p>
                        </div>
                        <div class="card-footer d-flex justify-content-between">
                            <span>📍 @proposal.DistrictName</span>
                            <span class="text-success fw-semibold">👍 @proposal.LikesCount</span>
                        </div>
                    </div>
                </div>
                rank++;
            }
        </div>
    }

    <!-- Districts -->
    <div class="mt-5 mb-4">
        <span class="section-tag">@L["Home.CoverageTag"]</span>
        <h2 class="section-title">@L["Home.DistrictsTitle"]</h2>
        <p class="section-subtitle">@L["Home.DistrictsSubtitle"]</p>
    </div>
    <div class="row g-2 mb-5">
        @foreach (var district in districts)
        {
            <div class="col-md-3 col-6">
                <a asp-controller="Proposals" asp-action="Index"
                   asp-route-districtId="@district.Id"
                   class="btn-district">
                    @district.Title
                </a>
            </div>
        }
    </div>

    <!-- How it works -->
    <div class="mt-5 mb-4">
        <span class="section-tag">@L["Home.ProcessTag"]</span>
        <h2 class="section-title">@L["Home.HowItWorks"]</h2>
    </div>
    <div class="row g-3 mb-5">
        @foreach (var step in new[] {
            ("1", L["Home.Step1Title"].Value, L["Home.Step1Text"].Value),
            ("2", L["Home.Step2Title"].Value, L["Home.Step2Text"].Value),
            ("3", L["Home.Step3Title"].Value, L["Home.Step3Text"].Value),
            ("4", L["Home.Step4Title"].Value, L["Home.Step4Text"].Value)
        })
        {
            <div class="col-md-3 col-6">
                <div class="card h-100 p-3">
                    <div class="feature-icon">@step.Item1</div>
                    <h6 style="color:#fff;font-weight:600;margin-bottom:0.3rem">@step.Item2</h6>
                    <p class="card-text small">@step.Item3</p>
                </div>
            </div>
        }
    </div>

    <!-- CTA -->
    @if (User.Identity?.IsAuthenticated != true)
    {
        <div class="cta-block mb-5">
            <span class="section-tag mb-2 d-block">@L["Home.JoinTag"]</span>
            <h2 class="section-title mb-2">@L["Home.CtaTitle"]</h2>
            <p style="color:rgba(255,255,255,0.5);margin-bottom:1.5rem">
                @L["Home.CtaSubtitle"]
            </p>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a asp-controller="Account" asp-action="Register" class="btn-brand">
                    @L["Home.SignUp"]
                </a>
                <a asp-controller="Proposals" asp-action="Index" class="btn-glass">
                    @L["Home.ViewProposalsPlain"]
                </a>
            </div>
        </div>
    }

</div>
