@{
    ViewData["Title"] = "404";
    Layout = "_Layout";
}

<div class="error-page">
    <div class="error-code">404</div>
    <h1 class="error-title">@L["Error.NotFoundTitle"]</h1>
    <p class="error-text">@L["Error.NotFoundText"]</p>
    <div class="d-flex gap-3 justify-content-center flex-wrap">
        <a asp-controller="Home" asp-action="Index" class="btn-brand">
            @L["Error.GoHome"]
        </a>
        <a asp-controller="Proposals" asp-action="Index" class="btn-glass">
            @L["Error.ViewProposals"]
        </a>
    </div>
</div>
