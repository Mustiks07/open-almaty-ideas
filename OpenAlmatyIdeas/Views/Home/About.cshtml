@{
    ViewData["Title"] = L["About.PageTitle"].Value;
}

<div class="container-xl px-4">

    <div class="page-header animate-fade-up">
        <h1>@L["About.PageTitle"]</h1>
        <p class="lead">@L["About.Subtitle"]</p>
    </div>

    <div class="row g-4">
        <div class="col-lg-9">

            <!-- What is OAI -->
            <section class="mb-5 animate-fade-up-d1">
                <span class="section-tag">@L["About.WhatIsTag"]</span>
                <h2 class="section-title mb-3">@L["About.WhatIsTitle"]</h2>
                <p style="color:rgba(255,255,255,0.7);line-height:1.85;font-size:1.05rem">
                    <strong style="color:#fff">Open Almaty Ideas</strong> — @L["About.WhatIsText"]
                </p>
            </section>

            <!-- Relevance -->
            <section class="mb-5 animate-fade-up-d2">
                <span class="section-tag">@L["About.RelevanceTag"]</span>
                <h2 class="section-title mb-4">@L["About.RelevanceTitle"]</h2>
                <div class="row g-3">
                    @foreach (var item in new[] {
                        L["About.Relevance1"].Value,
                        L["About.Relevance2"].Value,
                        L["About.Relevance3"].Value,
                        L["About.Relevance4"].Value,
                    })
                    {
                        <div class="col-md-6">
                            <div style="display:flex;gap:0.75rem;align-items:flex-start;padding:1rem 1.1rem;background:rgba(34,197,94,0.05);border:1px solid rgba(34,197,94,0.15);border-radius:12px">
                                <span style="color:var(--brand-400);font-weight:700;font-size:1rem;flex-shrink:0;margin-top:0.05rem">✓</span>
                                <span style="color:rgba(255,255,255,0.75);font-size:0.9rem;line-height:1.55">@item</span>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <!-- Innovation -->
            <section class="mb-5 animate-fade-up-d1">
                <span class="section-tag">@L["About.InnovationTag"]</span>
                <h2 class="section-title mb-4">@L["About.InnovationTitle"]</h2>
                <div class="row g-3">
                    @foreach (var item in new[] {
                        ("💡", L["About.Innovation1Title"].Value, L["About.Innovation1Text"].Value),
                        ("📊", L["About.Innovation2Title"].Value, L["About.Innovation2Text"].Value),
                        ("🌐", L["About.Innovation3Title"].Value, L["About.Innovation3Text"].Value),
                        ("💬", L["About.Innovation4Title"].Value, L["About.Innovation4Text"].Value),
                    })
                    {
                        <div class="col-md-6">
                            <div class="card p-3 h-100">
                                <div class="feature-icon">@item.Item1</div>
                                <h6 style="color:#fff;font-weight:600;margin-bottom:0.3rem">@item.Item2</h6>
                                <p class="card-text small mb-0">@item.Item3</p>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <!-- Mission -->
            <section class="mb-5 animate-fade-up-d2">
                <span class="section-tag">@L["About.MissionTag"]</span>
                <h2 class="section-title mb-3">@L["About.MissionTitle"]</h2>
                <p style="color:rgba(255,255,255,0.7);line-height:1.85;font-size:1rem">
                    @L["About.MissionText"]
                </p>
            </section>

            <!-- How it works -->
            <section class="mb-5 animate-fade-up-d1">
                <span class="section-tag">@L["About.ProcessTag"]</span>
                <h2 class="section-title mb-4">@L["About.ProcessTitle"]</h2>
                <div class="row g-3">
                    @foreach (var step in new[] {
                        ("1️⃣", L["About.Step1Title"].Value, L["About.Step1Text"].Value),
                        ("2️⃣", L["About.Step2Title"].Value, L["About.Step2Text"].Value),
                        ("3️⃣", L["About.Step3Title"].Value, L["About.Step3Text"].Value),
                        ("4️⃣", L["About.Step4Title"].Value, L["About.Step4Text"].Value)
                    })
                    {
                        <div class="col-md-6">
                            <div class="card p-3 h-100">
                                <div class="fs-2 mb-2">@step.Item1</div>
                                <h6 style="color:#fff;font-weight:600;margin-bottom:0.3rem">@step.Item2</h6>
                                <p class="card-text small mb-0">@step.Item3</p>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <!-- Expected results -->
            <section class="mb-5 animate-fade-up-d2">
                <span class="section-tag">@L["About.ResultsTag"]</span>
                <h2 class="section-title mb-4">@L["About.ResultsTitle"]</h2>
                <div class="row g-3">
                    @foreach (var result in new[] {
                        L["About.Result1"].Value,
                        L["About.Result2"].Value,
                        L["About.Result3"].Value,
                        L["About.Result4"].Value,
                    })
                    {
                        <div class="col-md-6">
                            <div style="display:flex;gap:0.75rem;align-items:flex-start;padding:1rem 1.1rem;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:12px">
                                <span style="color:var(--brand-400);font-size:1rem;flex-shrink:0;margin-top:0.05rem">→</span>
                                <span style="color:rgba(255,255,255,0.7);font-size:0.9rem;line-height:1.55">@result</span>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <!-- Districts coverage -->
            <section class="mb-5 animate-fade-up-d1">
                <span class="section-tag">@L["About.CoverageTag"]</span>
                <h2 class="section-title mb-2">@L["About.DistrictsTitle"]</h2>
                <p style="color:rgba(255,255,255,0.5);font-size:0.9rem;margin-bottom:1.25rem">
                    @L["About.DistrictsText"]
                </p>
                <div class="row g-2">
                    @foreach (var district in new[] { "Алмалы", "Әуезов", "Бостандық", "Жетісу", "Медеу", "Наурызбай", "Түрксіб", "Алатау" })
                    {
                        <div class="col-md-3 col-6">
                            <a asp-controller="Proposals" asp-action="Index" class="btn-district">@district</a>
                        </div>
                    }
                </div>
            </section>

            <!-- Categories -->
            <section class="mb-5 animate-fade-up-d2">
                <span class="section-tag">@L["About.CategoriesTag"]</span>
                <h2 class="section-title mb-3">@L["About.CategoriesTitle"]</h2>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var cat in new[] {
                        L["Cat.Transport"].Value, L["Cat.Ecology"].Value, L["Cat.Infrastructure"].Value,
                        L["Cat.Security"].Value, L["Cat.Education"].Value, L["Cat.Health"].Value,
                        L["Cat.Culture"].Value, L["Cat.Other"].Value
                    })
                    {
                        <span class="badge bg-secondary" style="font-size:0.85rem;padding:0.45em 1em">@cat</span>
                    }
                </div>
            </section>

            <!-- Statuses lifecycle -->
            <section class="mb-5 animate-fade-up-d1">
                <span class="section-tag">@L["About.LifecycleTag"]</span>
                <h2 class="section-title mb-3">@L["About.StatusesTitle"]</h2>
                <div class="row g-2">
                    @foreach (var status in new[] {
                        ("bg-warning",  L["About.Status.Pending"].Value,     L["About.Status.PendingDesc"].Value),
                        ("bg-primary",  L["About.Status.Accepted"].Value,    L["About.Status.AcceptedDesc"].Value),
                        ("bg-success",  L["About.Status.Implemented"].Value, L["About.Status.ImplementedDesc"].Value),
                        ("bg-danger",   L["About.Status.Rejected"].Value,    L["About.Status.RejectedDesc"].Value)
                    })
                    {
                        <div class="col-md-6">
                            <div style="display:flex;align-items:center;gap:0.75rem;padding:0.85rem 1rem;background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.06);border-radius:10px">
                                <span class="badge @status.Item1">@status.Item2</span>
                                <span style="color:rgba(255,255,255,0.55);font-size:0.875rem">@status.Item3</span>
                            </div>
                        </div>
                    }
                </div>
            </section>

            <!-- Author info -->
            <section class="mb-5 animate-fade-up-d2">
                <span class="section-tag">@L["About.AuthorTag"]</span>
                <h2 class="section-title mb-4">@L["About.AuthorTitle"]</h2>
                <div class="card p-4">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div style="color:rgba(255,255,255,0.4);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.12em;margin-bottom:0.4rem">@L["About.AuthorNameLabel"]</div>
                            <div style="color:#fff;font-weight:600;font-size:1.05rem">@L["About.AuthorName"]</div>
                        </div>
                        <div class="col-md-6">
                            <div style="color:rgba(255,255,255,0.4);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.12em;margin-bottom:0.4rem">@L["About.AuthorInstitutionLabel"]</div>
                            <div style="color:rgba(255,255,255,0.8)">@L["About.AuthorInstitution"]</div>
                        </div>
                        <div class="col-md-6">
                            <div style="color:rgba(255,255,255,0.4);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.12em;margin-bottom:0.4rem">@L["About.AuthorProgramLabel"]</div>
                            <div style="color:rgba(255,255,255,0.8)">@L["About.AuthorProgram"]</div>
                        </div>
                        <div class="col-md-6">
                            <div style="color:rgba(255,255,255,0.4);font-size:0.7rem;text-transform:uppercase;letter-spacing:0.12em;margin-bottom:0.4rem">@L["About.AuthorNoteLabel"]</div>
                            <div style="color:var(--brand-400);font-size:0.9rem">@L["About.AuthorNote"]</div>
                        </div>
                    </div>
                </div>
            </section>

            @if (User.Identity?.IsAuthenticated != true)
            {
                <div class="cta-block mb-5 animate-fade-up-d1">
                    <h2 class="section-title mb-2">@L["About.CtaTitle"]</h2>
                    <p style="color:rgba(255,255,255,0.5);margin-bottom:1.5rem">@L["About.CtaSubtitle"]</p>
                    <div class="d-flex gap-3 justify-content-center flex-wrap">
                        <a asp-controller="Account" asp-action="Register" class="btn-brand">
                            @L["About.SignUp"]
                        </a>
                        <a asp-controller="Proposals" asp-action="Index" class="btn-glass">
                            @L["About.ViewProposals"]
                        </a>
                    </div>
                </div>
            }

        </div>
    </div>

</div>
