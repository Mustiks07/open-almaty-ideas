<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Open Almaty Ideas</title>

    <!-- SEO -->
    <meta name="description" content="Open Almaty Ideas — платформа гражданских инициатив Алматы. Предлагайте идеи, голосуйте и улучшайте город вместе." />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph -->
    <meta property="og:title" content="@ViewData["Title"] — Open Almaty Ideas" />
    <meta property="og:description" content="Платформа для гражданских инициатив Алматы. Предлагайте идеи по улучшению города." />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ru_KZ" />
    <meta property="og:site_name" content="Open Almaty Ideas" />

    <!-- Favicon -->
    <link rel="icon" href="~/img/favicon.svg" type="image/svg+xml" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700;800&display=swap" rel="stylesheet" />

    <!-- Styles -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <partial name="_NavMenu" />

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container-xl px-4 text-center">
            Open Almaty Ideas &copy; @DateTime.Now.Year — @L["Footer.Text"]
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
