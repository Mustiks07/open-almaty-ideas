<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin — Open Almaty Ideas</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-danger">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/admin">
                ⚙️ Администратор
            </a>
            <div class="navbar-nav ms-auto">
                <a class="nav-link text-white" asp-controller="Home" asp-action="Index">
                    ← На сайт
                </a>
                <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                    <button type="submit" class="btn btn-outline-light btn-sm ms-2">Выйти</button>
                </form>
            </div>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">
            <!-- Боковое меню -->
            <nav class="col-md-2 col-lg-2 d-md-block bg-light sidebar py-4">
                <ul class="nav flex-column">
                    <li class="nav-item">
                        <a class="nav-link" href="/admin">Главная</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/proposals">Предложения</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/districts">Районы</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/admin/categories">Категории</a>
                    </li>
                </ul>
            </nav>

            <!-- Контент -->
            <main class="col-md-10 col-lg-10 px-md-4 py-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
