<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Admin — Open Almaty Ideas</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <!-- Admin topbar -->
    <nav style="position:fixed;top:0;left:0;right:0;z-index:1030;height:60px;background:rgba(127,29,29,0.95);backdrop-filter:blur(12px);border-bottom:1px solid rgba(239,68,68,0.2);display:flex;align-items:center">
        <div class="container-fluid px-4 d-flex align-items-center justify-content-between">
            <a href="/admin" style="color:#FCA5A5;font-weight:700;text-decoration:none;font-size:0.9rem;display:flex;align-items:center;gap:0.5rem">
                <span style="background:rgba(239,68,68,0.3);border-radius:8px;padding:0.25rem 0.5rem;font-size:0.75rem">⚙ ADMIN</span>
                Open Almaty Ideas
            </a>
            <div class="d-flex align-items-center gap-3">
                <a asp-controller="Home" asp-action="Index"
                   style="color:rgba(255,255,255,0.55);font-size:0.85rem;text-decoration:none">
                    ← На сайт
                </a>
                <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline">
                    <button type="submit" class="btn-glass btn-sm" style="color:#F87171;border-color:rgba(248,113,113,0.2)">
                        Выйти
                    </button>
                </form>
            </div>
        </div>
    </nav>

    <div style="padding-top:60px;display:flex;min-height:100vh">
        <!-- Sidebar -->
        <nav class="admin-sidebar d-none d-md-block" style="width:200px;flex-shrink:0">
            <p style="color:rgba(255,255,255,0.25);font-size:0.65rem;text-transform:uppercase;letter-spacing:0.15em;margin-bottom:0.5rem;padding:0 0.5rem">
                Управление
            </p>
            <ul class="nav flex-column gap-1">
                <li><a class="nav-link" href="/admin">Главная</a></li>
                <li><a class="nav-link" href="/admin/proposals">Предложения</a></li>
                <li><a class="nav-link" href="/admin/districts">Районы</a></li>
                <li><a class="nav-link" href="/admin/categories">Категории</a></li>
            </ul>
        </nav>

        <!-- Content -->
        <main style="flex:1;padding:2rem;min-width:0">
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
