@model IEnumerable<OpenAlmatyIdeas.Domain.Entities.Category>

@{
    ViewData["Title"] = L["Admin.Categories"].Value;
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>@L["Admin.Categories"]</h1>
    <a href="/admin/categories/edit" class="btn btn-success">@L["Admin.AddCategory"]</a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>@L["Admin.ColId"]</th>
            <th>@L["Admin.ColName"]</th>
            <th>@L["Admin.ColCount"]</th>
            <th>@L["Admin.ColActions"]</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var category in Model)
        {
            <tr>
                <td>@category.Id</td>
                <td>@category.Title</td>
                <td>@(category.Proposals?.Count ?? 0)</td>
                <td>
                    <a href="/admin/categories/edit/@category.Id" class="btn btn-sm btn-outline-primary">
                        @L["Admin.Edit"]
                    </a>
                    <form action="/admin/categories/delete/@category.Id" method="post" class="d-inline"
                          onsubmit="return confirm('@L["Admin.DeleteCategoryConfirm"]')">
                        <button type="submit" class="btn btn-sm btn-outline-danger">@L["Admin.Delete"]</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
