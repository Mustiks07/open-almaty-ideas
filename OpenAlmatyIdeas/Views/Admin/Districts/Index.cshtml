@model IEnumerable<OpenAlmatyIdeas.Domain.Entities.District>

@{
    ViewData["Title"] = "Районы";
    Layout = "_AdminLayout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Районы</h1>
    <a href="/admin/districts/edit" class="btn btn-success">+ Добавить район</a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>#</th>
            <th>Название</th>
            <th>Предложений</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var district in Model)
        {
            <tr>
                <td>@district.Id</td>
                <td>@district.Title</td>
                <td>@(district.Proposals?.Count ?? 0)</td>
                <td>
                    <a href="/admin/districts/edit/@district.Id" class="btn btn-sm btn-outline-primary">
                        Изменить
                    </a>
                    <form action="/admin/districts/delete/@district.Id" method="post" class="d-inline"
                          onsubmit="return confirm('Удалить район?')">
                        <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
