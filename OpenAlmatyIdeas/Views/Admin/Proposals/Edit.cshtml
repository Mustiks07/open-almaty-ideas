@model OpenAlmatyIdeas.Domain.Entities.Proposal

@{
    ViewData["Title"] = L["Admin.EditProposalTitle"].Value;
    Layout = "_AdminLayout";
    var statuses = ViewBag.Statuses as IEnumerable<OpenAlmatyIdeas.Domain.Enums.ProposalStatusEnum>;
}

<h1 class="mb-4">@L["Admin.EditProposalTitle"] #@Model.Id</h1>

<div class="row">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-body">
                <h4>@Model.Title</h4>
                <p class="text-muted">
                    📍 @Model.District?.Title &bull;
                    🏷️ @Model.Category?.Title &bull;
                    👤 @Model.Author?.UserName
                </p>
                <p>@Model.DescriptionShort</p>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div>@Html.Raw(Model.Description)</div>
                }
            </div>
        </div>

        <form asp-action="Edit" method="post">
            <input type="hidden" name="id" value="@Model.Id" />

            <div class="mb-3">
                <label class="form-label">@L["Admin.StatusLabel"]</label>
                <select name="status" class="form-select">
                    @foreach (var status in statuses ?? [])
                    {
                        <option value="@status" selected="@(Model.Status == status)">
                            @L[$"Status.{status}"]
                        </option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">@L["Admin.AdminResponse"]</label>
                <textarea name="adminResponseText" class="form-control" rows="4"
                          placeholder="@L["Admin.AdminResponsePlaceholder"]"></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">@L["Admin.Save"]</button>
                <a href="/admin/proposals" class="btn btn-outline-secondary">@L["Admin.Cancel"]</a>
            </div>
        </form>
    </div>
</div>
