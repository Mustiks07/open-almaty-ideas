@model OpenAlmatyIdeas.Domain.Entities.Proposal

@{
    ViewData["Title"] = "Редактирование предложения";
    Layout = "_AdminLayout";
    var statuses = ViewBag.Statuses as IEnumerable<OpenAlmatyIdeas.Domain.Enums.ProposalStatusEnum>;
}

<h1 class="mb-4">Редактирование предложения #@Model.Id</h1>

<div class="row">
    <div class="col-md-8">
        <div class="card mb-4">
            <div class="card-body">
                <h4>@Model.Title</h4>
                <p class="text-muted">
                    📍 @Model.District?.Title &bull;
                    🏷️ @Model.Category?.Title &bull;
                    👤 @Model.Author?.UserName
                </p>
                <p>@Model.DescriptionShort</p>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <div>@Html.Raw(Model.Description)</div>
                }
            </div>
        </div>

        <form asp-action="Edit" method="post">
            <input type="hidden" name="id" value="@Model.Id" />

            <div class="mb-3">
                <label class="form-label">Статус</label>
                <select name="status" class="form-select">
                    @foreach (var status in statuses ?? [])
                    {
                        <option value="@status" selected="@(Model.Status == status)">
                            @(status switch {
                                OpenAlmatyIdeas.Domain.Enums.ProposalStatusEnum.Pending => "На рассмотрении",
                                OpenAlmatyIdeas.Domain.Enums.ProposalStatusEnum.Accepted => "Принято",
                                OpenAlmatyIdeas.Domain.Enums.ProposalStatusEnum.Rejected => "Отклонено",
                                OpenAlmatyIdeas.Domain.Enums.ProposalStatusEnum.Implemented => "Реализовано",
                                _ => status.ToString()
                            })
                        </option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Ответ администратора (необязательно)</label>
                <textarea name="adminResponseText" class="form-control" rows="4"
                          placeholder="Введите комментарий к решению..."></textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success">Сохранить</button>
                <a href="/admin/proposals" class="btn btn-outline-secondary">Отмена</a>
            </div>
        </form>
    </div>
</div>
