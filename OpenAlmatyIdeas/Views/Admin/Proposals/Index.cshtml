@model IEnumerable<OpenAlmatyIdeas.Models.ProposalDTO>

@{
    ViewData["Title"] = L["Admin.Proposals"].Value;
    Layout = "_AdminLayout";
}

<h1 class="mb-4">@L["Admin.Proposals"]</h1>

<div class="table-responsive">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>@L["Admin.ColId"]</th>
                <th>@L["Admin.ColName"]</th>
                <th>@L["Admin.ColDistrict"]</th>
                <th>@L["Admin.ColCategory"]</th>
                <th>@L["Admin.ColAuthor"]</th>
                <th>@L["Admin.ColStatus"]</th>
                <th>👍</th>
                <th>@L["Admin.ColDate"]</th>
                <th>@L["Admin.ColActions"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var proposal in Model)
            {
                <tr>
                    <td>@proposal.Id</td>
                    <td>
                        <a asp-controller="Proposals" asp-action="Show" asp-route-id="@proposal.Id"
                           target="_blank">@proposal.Title</a>
                    </td>
                    <td>@proposal.DistrictName</td>
                    <td>@proposal.CategoryName</td>
                    <td>@proposal.AuthorName</td>
                    <td>
                        <span class="badge
                            @(proposal.Status == OpenAlmatyIdeas.Domain.Enums.ProposalStatusEnum.Implemented ? "bg-success" :
                              proposal.Status == OpenAlmatyIdeas.Domain.Enums.ProposalStatusEnum.Accepted ? "bg-primary" :
                              proposal.Status == OpenAlmatyIdeas.Domain.Enums.ProposalStatusEnum.Rejected ? "bg-danger" :
                              "bg-warning text-dark")">
                            @L[$"Status.{proposal.Status}"]
                        </span>
                    </td>
                    <td>@proposal.LikesCount</td>
                    <td>@proposal.DateCreated.ToString("dd.MM.yyyy")</td>
                    <td>
                        <a href="/admin/proposals/edit/@proposal.Id" class="btn btn-sm btn-outline-primary">
                            @L["Admin.Edit"]
                        </a>
                        <form action="/admin/proposals/delete/@proposal.Id" method="post" class="d-inline"
                              onsubmit="return confirm('@L["Admin.DeleteProposalConfirm"]')">
                            <button type="submit" class="btn btn-sm btn-outline-danger">@L["Admin.Delete"]</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
