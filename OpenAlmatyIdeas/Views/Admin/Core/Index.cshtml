@{
    ViewData["Title"] = L["Admin.DashboardTitle"].Value;
    Layout = "_AdminLayout";
}

<h1 class="mb-4">@L["Admin.DashboardTitle"]</h1>

<div class="row">
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@L["Admin.Proposals"]</h5>
                <p class="card-text">@L["Admin.ProposalsDesc"]</p>
                <a href="/admin/proposals" class="btn btn-primary">@L["Admin.Manage"]</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@L["Admin.Districts"]</h5>
                <p class="card-text">@L["Admin.DistrictsDesc"]</p>
                <a href="/admin/districts" class="btn btn-primary">@L["Admin.Manage"]</a>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-3">
        <div class="card">
            <div class="card-body">
                <h5 class="card-title">@L["Admin.Categories"]</h5>
                <p class="card-text">@L["Admin.CategoriesDesc"]</p>
                <a href="/admin/categories" class="btn btn-primary">@L["Admin.Manage"]</a>
            </div>
        </div>
    </div>
</div>
