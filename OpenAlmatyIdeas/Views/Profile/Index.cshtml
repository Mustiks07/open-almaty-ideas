@model IEnumerable<ProposalDTO>

@{
    ViewData["Title"] = "Мои предложения";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Мои предложения</h1>
    <a asp-controller="Proposals" asp-action="New" class="btn btn-success">+ Новое предложение</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        У вас пока нет предложений.
        <a asp-controller="Proposals" asp-action="New">Подайте первое!</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Название</th>
                    <th>Район</th>
                    <th>Категория</th>
                    <th>Статус</th>
                    <th>👍</th>
                    <th>👎</th>
                    <th>Дата</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var proposal in Model)
                {
                    <tr>
                        <td>
                            <a asp-controller="Proposals" asp-action="Show"
                               asp-route-id="@proposal.Id" class="fw-semibold text-decoration-none">
                                @proposal.Title
                            </a>
                        </td>
                        <td><small>@proposal.DistrictName</small></td>
                        <td><small>@proposal.CategoryName</small></td>
                        <td>
                            <span class="badge
                                @(proposal.Status == ProposalStatusEnum.Implemented ? "bg-success" :
                                  proposal.Status == ProposalStatusEnum.Accepted ? "bg-primary" :
                                  proposal.Status == ProposalStatusEnum.Rejected ? "bg-danger" :
                                  "bg-warning text-dark")">
                                @proposal.StatusLabel
                            </span>
                        </td>
                        <td class="text-success">@proposal.LikesCount</td>
                        <td class="text-danger">@proposal.DislikesCount</td>
                        <td><small class="text-muted">@proposal.DateCreated.ToString("dd.MM.yyyy")</small></td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-controller="Proposals" asp-action="Edit"
                                   asp-route-id="@proposal.Id"
                                   class="btn btn-sm btn-outline-primary">Изменить</a>
                                <form asp-controller="Proposals" asp-action="Delete"
                                      asp-route-id="@proposal.Id" method="post"
                                      onsubmit="return confirm('Удалить предложение?')">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
