@model IEnumerable<ProposalDTO>

@{
    ViewData["Title"] = "Мои предложения";
}

<div class="container-xl px-4">

    <div class="page-header d-flex align-items-center justify-content-between">
        <div>
            <h1>Мои предложения</h1>
            <p class="lead">@User.Identity?.Name</p>
        </div>
        <a asp-controller="Proposals" asp-action="New" class="btn-brand">+ Новое предложение</a>
    </div>

    @if (!Model.Any())
    {
        <div style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.07);border-radius:16px;padding:3rem;text-align:center">
            <p style="color:rgba(255,255,255,0.4);font-size:0.95rem;margin-bottom:1.5rem">
                У вас пока нет предложений
            </p>
            <a asp-controller="Proposals" asp-action="New" class="btn-brand">Создать первое предложение</a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Название</th>
                        <th>Район</th>
                        <th>Категория</th>
                        <th>Статус</th>
                        <th>Голоса</th>
                        <th>Дата</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var proposal in Model)
                    {
                        <tr>
                            <td>
                                <a asp-controller="Proposals" asp-action="Show"
                                   asp-route-id="@proposal.Id"
                                   style="color:#fff;font-weight:500;text-decoration:none">
                                    @proposal.Title
                                </a>
                            </td>
                            <td style="color:rgba(255,255,255,0.5);font-size:0.85rem">@proposal.DistrictName</td>
                            <td><span class="badge bg-secondary">@proposal.CategoryName</span></td>
                            <td>
                                <span class="badge
                                    @(proposal.Status == ProposalStatusEnum.Implemented ? "bg-success" :
                                      proposal.Status == ProposalStatusEnum.Accepted ? "bg-primary" :
                                      proposal.Status == ProposalStatusEnum.Rejected ? "bg-danger" :
                                      "bg-warning")">
                                    @proposal.StatusLabel
                                </span>
                            </td>
                            <td style="font-size:0.85rem">
                                <span class="text-success">👍 @proposal.LikesCount</span>
                                <span class="ms-1" style="color:#F87171">👎 @proposal.DislikesCount</span>
                            </td>
                            <td style="color:rgba(255,255,255,0.4);font-size:0.8rem">
                                @proposal.DateCreated.ToString("dd.MM.yyyy")
                            </td>
                            <td>
                                <div class="d-flex gap-1">
                                    <a asp-controller="Proposals" asp-action="Edit" asp-route-id="@proposal.Id"
                                       class="btn-glass btn-sm" style="color:#93C5FD;border-color:rgba(147,197,253,0.2)">
                                        ✏
                                    </a>
                                    <form asp-controller="Proposals" asp-action="Delete"
                                          asp-route-id="@proposal.Id" method="post" style="display:inline">
                                        <button type="submit"
                                                class="btn-glass btn-sm"
                                                style="color:#F87171;border-color:rgba(248,113,113,0.2)"
                                                onclick="return confirm('Удалить предложение «@proposal.Title»?')">
                                            🗑
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <p style="color:rgba(255,255,255,0.3);font-size:0.8rem;margin-top:0.5rem">
            Всего: @Model.Count() предложений
        </p>
    }

</div>
