@model LoginViewModel

@{
    ViewData["Title"] = "Авторизация Администратора";
    var returnUrl = ViewBag.ReturnUrl;
}

<div class="row justify-content-center" style="margin-top: 5rem;">
    <div class="col-md-5">
        <div class="text-center mb-4">
            <h1 style="color:#f87171; font-weight:800; font-size:2rem; letter-spacing:1px; margin-bottom:0">OPEN ALMATY</h1>
            <p style="color:rgba(255,255,255,0.5); font-size:0.9rem; text-transform:uppercase; letter-spacing:2px">SECURE ADMIN PORTAL</p>
        </div>

        <div style="background:rgba(20,20,25,0.95); border:1px solid rgba(248,113,113,0.15); border-radius:12px; padding:2rem; box-shadow:0 10px 30px rgba(0,0,0,0.5)">
            <form asp-action="AdminLogin" asp-route-returnUrl="@returnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="background:rgba(248,113,113,0.1);border-color:rgba(248,113,113,0.2);color:#f87171;font-size:0.85rem"></div>

                <div class="mb-3">
                    <label asp-for="UserName" class="form-label" style="color:rgba(255,255,255,0.7);font-size:0.85rem;text-transform:uppercase;letter-spacing:1px">Логин (Email)</label>
                    <input asp-for="UserName" class="form-control" style="background:rgba(0,0,0,0.5);border:1px solid rgba(255,255,255,0.1);color:#fff;border-radius:6px" placeholder="admin@openalmaty.kz" required />
                    <span asp-validation-for="UserName" class="text-danger" style="font-size:0.8rem"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="Password" class="form-label" style="color:rgba(255,255,255,0.7);font-size:0.85rem;text-transform:uppercase;letter-spacing:1px">Пароль</label>
                    <input asp-for="Password" class="form-control" style="background:rgba(0,0,0,0.5);border:1px solid rgba(255,255,255,0.1);color:#fff;border-radius:6px" placeholder="Ввести пароль..." required />
                    <span asp-validation-for="Password" class="text-danger" style="font-size:0.8rem"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="RememberMe" class="form-check-input" style="background-color:transparent;border-color:rgba(248,113,113,0.5)" />
                    <label asp-for="RememberMe" class="form-check-label" style="color:rgba(255,255,255,0.5);font-size:0.85rem">Запомнить меня для этой сессии</label>
                </div>

                <button type="submit" class="btn w-100 py-2" style="background:#f87171;color:#fff;font-weight:600;letter-spacing:1px;border-radius:6px;transition:all 0.2sease">
                    ВОЙТИ В ПАНЕЛЬ
                </button>

                <div class="mt-3 text-center">
                    <a asp-controller="Home" asp-action="Index" style="color:rgba(255,255,255,0.3);font-size:0.8rem;text-decoration:none">← Вернуться на публичный сайт</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
